#!/bin/sh
/etc/init.d/raven enable
/etc/init.d/raven start
/usr/local/bin/restart-firewall

# Fixup badge color in 4.26.1.0
user_css='/app/resource/css/user.css'
color_override='#apps .app-user > div { color: #f0f0f0; }'
result=$(grep "${color_override}" ${user_css})
if [ "${result}" == "" ]; then
    echo "${color_override}" >> ${user_css}
    sh -c 'sleep 5; /etc/init.d/uhttpd restart' &
fi

exit 0
